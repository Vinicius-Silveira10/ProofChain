# === SERVIDOR ===
NODE_ENV=development
PORT=3001

# === JWT ===
JWT_SECRET=troque-por-uma-string-aleatoria-longa-em-producao
JWT_EXPIRES_IN=8h

# === BANCO DE DADOS ===
DATABASE_URL=postgresql://proofchain:senha123@localhost:5432/proofchain_db

# === BLOCKCHAIN (Ethereum Sepolia Testnet) ===
# Obter URL gratuita em: https://www.infura.io ou https://www.alchemy.com
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/SEU_PROJECT_ID_AQUI

# ATENÇÃO: NUNCA commitar a chave real. Use uma wallet exclusiva para o backend.
# Obter ETH de teste em: https://sepoliafaucet.com
BACKEND_WALLET_PRIVATE_KEY=0xSUA_CHAVE_PRIVADA_AQUI

# Endereço do contrato após o deploy (preencher depois do TASK 02.3)
CONTRACT_ADDRESS=0xENDERECO_DO_CONTRATO_APOS_DEPLOY

# === CORS ===
CORS_ALLOWED_ORIGINS=http://localhost:3000
