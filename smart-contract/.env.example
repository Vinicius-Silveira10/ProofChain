# === BLOCKCHAIN (Ethereum Sepolia Testnet) ===

# URL do RPC — obter gratuitamente em:
#   https://www.infura.io  ou  https://www.alchemy.com
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/SEU_PROJECT_ID_AQUI

# Chave privada da wallet exclusiva do backend.
# ATENÇÃO: NUNCA commitar a chave real. Use uma wallet dedicada — JAMAIS a principal.
# Obter ETH de teste em: https://sepoliafaucet.com (saldo mínimo recomendado: 0.05 ETH)
BACKEND_WALLET_PRIVATE_KEY=0xSUA_CHAVE_PRIVADA_AQUI

# Chave da API do Etherscan para verificação automática do contrato (opcional).
# Obter em: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=SUA_CHAVE_DO_ETHERSCAN_AQUI

# Endereço do contrato após o deploy (preenchido automaticamente pelo script deploy.ts).
# Copiar este valor para /backend/.env após executar: npm run deploy
CONTRACT_ADDRESS=0xENDERECO_DO_CONTRATO_APOS_DEPLOY
